{
  "main": "index.html",
  "title": "{{title}}",
  "description": "CodeExpander plugin: {{title}} (Python stdio backend)",
  "category": "tools",
  "order": 100,
  "features": [
    { "code": "{{project-name-kebab}}", "explain": "{{title}}", "cmds": ["{{project-name-kebab}}"] }
  ],
  "pluginSetting": { "height": 400, "width": 500 },
  "backend": {
    "runtime": "python3",
    "entry": "backend.py",
    "mode": "stdio"
  }
}
